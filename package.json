{
  "name": "selfmend",
  "version": "0.2.3",
  "description": "Self-healing Playwright locators for any framework that drives a Playwright Page: Cucumber, Mocha, Jest, plain scripts, or @playwright/test. Fully offline, no API key, no telemetry, never a false-green test.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/BilalEjaz/selfmend.git"
  },
  "homepage": "https://github.com/BilalEjaz/selfmend#readme",
  "bugs": {
    "url": "https://github.com/BilalEjaz/selfmend/issues"
  },
  "keywords": [
    "playwright",
    "playwright-test",
    "cucumber",
    "mocha",
    "jest",
    "bdd",
    "runner-agnostic",
    "self-healing",
    "selfhealing",
    "locators",
    "testing",
    "e2e",
    "end-to-end",
    "flaky-tests",
    "test-automation",
    "offline"
  ],
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.cts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./reporter": {
      "import": {
        "types": "./dist/reporter.d.mts",
        "default": "./dist/reporter.mjs"
      },
      "require": {
        "types": "./dist/reporter.d.cts",
        "default": "./dist/reporter.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsdown",
    "demo": "npm run build && node demo/run-demo.mjs",
    "test": "vitest run src",
    "test:watch": "vitest src",
    "test:e2e": "playwright test",
    "typecheck": "tsc --noEmit",
    "lint:pack": "publint --pack npm",
    "lint:types": "node scripts/check-types.mjs",
    "check:examples": "node scripts/check-examples.mjs",
    "check:readme": "node scripts/check-readme-examples.mjs",
    "verify": "npm run build && npm run lint:pack && npm run lint:types && npm run typecheck && npm run check:examples && npm run check:readme && npm test",
    "prepublishOnly": "npm run build && npm run lint:pack"
  },
  "peerDependencies": {
    "@playwright/test": ">=1.42"
  },
  "dependencies": {
    "picocolors": "^1",
    "zod": "^4"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18",
    "@playwright/test": "^1.60",
    "@types/node": "^24",
    "publint": "^0.3",
    "tsdown": "^0.22",
    "typescript": "^6",
    "vitest": "^4"
  }
}
